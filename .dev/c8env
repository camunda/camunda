# ─── Main ────────────────────────────────────────────────────────────────────

main() {
  printf "\n  ${BOLD}🔧 Camunda 8 Dev Environment Generator${RESET}\n"

  case "${1:-}" in
    help|--help|-h)
      cmd_help
      ;;
    list)
      cmd_list
      ;;
    clean)
      shift
      cmd_clean "${1:-}"
      ;;
    deploy)
      shift
      cmd_deploy "${1:-}"
      ;;
    start)
      shift
      cmd_start "$@"
      ;;
    dashboard)
      shift
      cmd_dashboard "${1:-}"
      ;;
    *)
      cmd_generate "$@"
      ;;
  esac
}

main "$@"
