<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="agentic-daily-briefing" name="Agentic Daily Briefing" isExecutable="true">
    <bpmn:startEvent id="StartEvent" name="Start">
      <bpmn:outgoing>Flow_ToAgent</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_ToAgent" sourceRef="StartEvent" targetRef="AI_Agent" />
    <bpmn:adHocSubProcess id="AI_Agent" name="Daily Briefing Agent" zeebe:modelerTemplate="io.camunda.connectors.agenticai.aiagent.jobworker.v1" zeebe:modelerTemplateVersion="6" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:adHoc outputCollection="toolCallResults" outputElement="={&#10;  id: toolCall._meta.id,&#10;  name: toolCall._meta.name,&#10;  content: toolCallResult&#10;}" />
        <zeebe:taskDefinition type="io.camunda.agenticai:aiagent-job-worker:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="openaiCompatible" target="provider.type" />
          <zeebe:input source="http://host.docker.internal:11434/v1" target="provider.openaiCompatible.endpoint" />
          <zeebe:input source="not-needed" target="provider.openaiCompatible.authentication.apiKey" />
          <zeebe:input source="qwen3:0.6b" target="provider.openaiCompatible.model.model" />
          <zeebe:input source="=2048" target="provider.openaiCompatible.model.parameters.maxCompletionTokens" />
          <zeebe:input source="=0.3" target="provider.openaiCompatible.model.parameters.temperature" />
          <zeebe:input source="=&#34;You are a helpful daily briefing assistant. Gather information using the available tools and compile a concise daily briefing.&#10;&#10;Use the tools to:&#10;1. Get the current date and time (or use the provided date if given)&#10;2. Fetch weather for the user&#39;s location&#10;3. Look up what happened on this day in history&#10;&#10;Compile all information into a friendly, concise daily briefing.&#10;Always use the tools - do not make up information.&#34;" target="data.systemPrompt.prompt" />
          <zeebe:input source="=if briefingDate != null then &#34;Give me a daily briefing for &#34; + briefingDate + &#34;. My location is Berlin, Germany (latitude 52.52, longitude 13.41). Include weather, and historical events for that date.&#34; else &#34;Give me a daily briefing for today. My location is Berlin, Germany (latitude 52.52, longitude 13.41). Include current weather, time, and historical events for today.&#34;" target="data.userPrompt.prompt" />
          <zeebe:input target="agentContext" />
          <zeebe:input source="in-process" target="data.memory.storage.type" />
          <zeebe:input source="=20" target="data.memory.contextWindowSize" />
          <zeebe:input source="=10" target="data.limits.maxModelCalls" />
          <zeebe:input source="WAIT_FOR_TOOL_CALL_RESULTS" target="data.events.behavior" />
          <zeebe:input source="text" target="data.response.format.type" />
          <zeebe:input source="=false" target="data.response.format.parseJson" />
          <zeebe:input source="=true" target="data.response.includeAssistantMessage" />
          <zeebe:input source="=false" target="data.response.includeAgentContext" />
          <zeebe:output source="=agent" target="agent" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="6" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.aiagent.jobworker.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToAgent</bpmn:incoming>
      <bpmn:outgoing>Flow_ToResult</bpmn:outgoing>
      <bpmn:scriptTask id="GetDateTime" name="Get Date and Time">
        <bpmn:documentation>Returns the current date and time including the timezone.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:script expression="=now()" resultVariable="toolCallResult" />
        </bpmn:extensionElements>
      </bpmn:scriptTask>
      <bpmn:serviceTask id="GetWeather" name="Get Weather" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12">
        <bpmn:documentation>Fetches current weather data for a given latitude and longitude. Returns temperature, wind speed, and weather conditions.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:http-json:1" retries="1" />
          <zeebe:ioMapping>
            <zeebe:input source="noAuth" target="authentication.type" />
            <zeebe:input source="GET" target="method" />
            <zeebe:input source="https://api.open-meteo.com/v1/forecast" target="url" />
            <zeebe:input source="={&#10;  &#34;latitude&#34;: fromAi(toolCall.latitude, &#34;Latitude of the location&#34;, &#34;number&#34;),&#10;  &#34;longitude&#34;: fromAi(toolCall.longitude, &#34;Longitude of the location&#34;, &#34;number&#34;),&#10;  &#34;current&#34;: &#34;temperature_2m,relative_humidity_2m,weather_code,wind_speed_10m&#34;,&#10;  &#34;timezone&#34;: &#34;auto&#34;&#10;}" target="queryParameters" />
            <zeebe:input source="20" target="connectionTimeoutInSeconds" />
            <zeebe:input source="20" target="readTimeoutInSeconds" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="12" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
            <zeebe:header key="resultExpression" value="={&#10;  toolCallResult: response.body.current&#10;}" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="GetWikipediaEvents" name="On This Day" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12">
        <bpmn:documentation>Fetches notable historical events that happened on a given month and day. Provide month (1-12) and day (1-31) as numbers. If unsure, use the current month and day.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:http-json:1" retries="1" />
          <zeebe:ioMapping>
            <zeebe:input source="noAuth" target="authentication.type" />
            <zeebe:input source="GET" target="method" />
            <zeebe:input source="=&#34;https://byabbe.se/on-this-day/&#34; + string(fromAi(toolCall.month, &#34;Month number 1-12&#34;, &#34;number&#34;)) + &#34;/&#34; + string(fromAi(toolCall.day, &#34;Day number 1-31&#34;, &#34;number&#34;)) + &#34;/events.json&#34;" target="url" />
            <zeebe:input source="20" target="connectionTimeoutInSeconds" />
            <zeebe:input source="20" target="readTimeoutInSeconds" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="12" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
            <zeebe:header key="resultExpression" value="={&#10;  toolCallResult: for event in response.body.events[position &#60;= 5] return {&#10;    year: event.year,&#10;    text: event.description&#10;  }&#10;}" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
    </bpmn:adHocSubProcess>
    <bpmn:sequenceFlow id="Flow_ToResult" sourceRef="AI_Agent" targetRef="FormatResult" />
    <bpmn:scriptTask id="FormatResult" name="Format Result">
      <bpmn:extensionElements>
        <zeebe:script expression="={&#10;  dateTime: (for r in toolCallResults return if r.name = &#34;GetDateTime&#34; then r.content else null)[item != null][1],&#10;  weather: (for r in toolCallResults return if r.name = &#34;GetWeather&#34; then r.content else null)[item != null][1],&#10;  events: (for r in toolCallResults return if r.name = &#34;GetWikipediaEvents&#34; then r.content else null)[item != null][1],&#10;  dailyBriefing: string join([&#10;    &#34;=== Daily Briefing ===&#34;,&#10;    &#34;&#34;,&#10;    &#34;Date: &#34; + string(dateTime),&#10;    &#34;&#34;,&#10;    &#34;Weather: &#34; + string(weather.temperature_2m) + &#34;°C, wind &#34; + string(weather.wind_speed_10m) + &#34; km/h, humidity &#34; + string(weather.relative_humidity_2m) + &#34;%&#34;,&#10;    &#34;&#34;,&#10;    &#34;On This Day:&#34;,&#10;    string join(for e in events[position &#60;= 3] return &#34;  - &#34; + string(e.year) + &#34;: &#34; + e.text, &#34;&#10;&#34;)&#10;  ], &#34;&#10;&#34;)&#10;}.dailyBriefing" resultVariable="dailyBriefing" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToResult</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEnd</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:sequenceFlow id="Flow_ToEnd" sourceRef="FormatResult" targetRef="EndEvent" />
    <bpmn:endEvent id="EndEvent" name="Briefing Complete">
      <bpmn:incoming>Flow_ToEnd</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="agentic-daily-briefing">
      <bpmndi:BPMNShape id="StartEvent_di" bpmnElement="StartEvent">
        <dc:Bounds x="152" y="232" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="159" y="275" width="24" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="AI_Agent_di" bpmnElement="AI_Agent" isExpanded="true">
        <dc:Bounds x="250" y="110" width="560" height="280" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GetDateTime_di" bpmnElement="GetDateTime">
        <dc:Bounds x="290" y="150" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GetWeather_di" bpmnElement="GetWeather">
        <dc:Bounds x="470" y="150" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GetWikipediaEvents_di" bpmnElement="GetWikipediaEvents">
        <dc:Bounds x="650" y="150" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="FormatResult_di" bpmnElement="FormatResult">
        <dc:Bounds x="870" y="210" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_di" bpmnElement="EndEvent">
        <dc:Bounds x="1032" y="232" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1008" y="275" width="86" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_ToAgent_di" bpmnElement="Flow_ToAgent">
        <di:waypoint x="188" y="250" />
        <di:waypoint x="250" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToResult_di" bpmnElement="Flow_ToResult">
        <di:waypoint x="810" y="250" />
        <di:waypoint x="870" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToEnd_di" bpmnElement="Flow_ToEnd">
        <di:waypoint x="970" y="250" />
        <di:waypoint x="1032" y="250" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
