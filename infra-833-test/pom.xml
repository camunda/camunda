    </developer>
  </developers>

  <scm>
    <connection>scm:git:https://github.com/clementnero/maven-poc-833.git</connection>
    <developerConnection>scm:git:https://github.com/clementnero/maven-poc-833.git</developerConnection>
    <tag>infra-833-test-1.0.0</tag>
    <url>https://github.com/clementnero/maven-poc-833</url>
