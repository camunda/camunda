  <groupId>io.github.clementnero.maven-poc-833.camunda.camunda</groupId>
  <artifactId>infra-833-test</artifactId>
  <version>1.0.1-SNAPSHOT</version>
  <packaging>pom</packaging>

  <name>Infra 833 Test</name>
  <description>Submodule used to to test migration of Maven Central publishing to Central Portal (INFRA-833)</description>
  <url>https://github.com/camunda/team-infrastructure/issues/833</url>

  <licenses>
    <license>
      <name>The Apache Software License, Version 2.0</name>
      <url>https://www.apache.org/licenses/LICENSE-2.0.txt</url>
    </license>
