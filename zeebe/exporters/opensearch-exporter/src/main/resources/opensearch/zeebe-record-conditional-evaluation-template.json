{
  "index_patterns": [
    "zeebe-record_conditional-evaluation_*"
  ],
  "composed_of": ["zeebe-record"],
  "priority": 20,
  "version": 1,
  "template": {
    "settings": {
      "index": {
        "number_of_shards": "1",
        "number_of_replicas": "0",
        "queries": {
          "cache": {
            "enabled": false
          }
        }
      }
    },
    "aliases": {
      "zeebe-record-conditional-evaluation": {}
    },
    "mappings": {
      "properties": {
        "value": {
          "dynamic": "strict",
          "properties": {
            "processDefinitionKey": {
              "type": "long"
            },
            "variables": {
              "enabled": false
            },
            "tenantId": {
              "type": "keyword"
            }
          }
        }
      }
    }
  }
}
