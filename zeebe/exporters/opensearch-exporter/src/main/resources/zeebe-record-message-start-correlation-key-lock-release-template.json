{
  "index_patterns": [
    "zeebe-record_message-start-correlation-key-lock-release_*"
  ],
  "composed_of": [
    "zeebe-record"
  ],
  "priority": 20,
  "version": 1,
  "template": {
    "settings": {
      "index": {
        "number_of_shards": "1",
        "number_of_replicas": "0",
        "queries": {
          "cache": {
            "enabled": false
          }
        }
      }
    },
    "aliases": {
      "zeebe-record-message-start-correlation-key-lock-release": {}
    },
    "mappings": {
      "properties": {
        "value": {
          "dynamic": "strict",
          "properties": {
            "requestKey": {
              "type": "long"
            },
            "holders": {
              "type": "nested",
              "dynamic": "strict",
              "properties": {
                "processInstanceKey": {
                  "type": "long"
                },
                "bpmnProcessId": {
                  "type": "keyword"
                },
                "correlationKey": {
                  "type": "text"
                },
                "tenantId": {
                  "type": "keyword"
                }
              }
            }
          }
        }
      }
    }
  }
}

