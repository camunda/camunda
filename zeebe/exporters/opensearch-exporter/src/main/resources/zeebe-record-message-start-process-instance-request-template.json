{
  "index_patterns": [
    "zeebe-record_message-start-process-instance-request_*"
  ],
  "composed_of": ["zeebe-record"],
  "priority": 20,
  "version": 1,
  "template": {
    "settings": {
      "index": {
        "number_of_shards": "1",
        "number_of_replicas": "0",
        "queries": {
          "cache": {
            "enabled": false
          }
        }
      }
    },
    "aliases": {
      "zeebe-record-message-start-process-instance-request": {}
    },
    "mappings": {
      "properties": {
        "value": {
          "dynamic": "strict",
          "properties": {
            "messageKey": {
              "type": "long"
            },
            "messageName": {
              "type": "keyword"
            },
            "correlationKey": {
              "type": "text"
            },
            "businessId": {
              "type": "keyword"
            },
            "processDefinitionKey": {
              "type": "long"
            },
            "bpmnProcessId": {
              "type": "keyword"
            },
            "startEventId": {
              "type": "keyword"
            },
            "messageStartEventSubscriptionKey": {
              "type": "long"
            },
            "processInstanceKey": {
              "type": "long"
            },
            "variables": {
              "enabled": false
            },
            "tenantId": {
              "type": "keyword"
            }
          }
        }
      }
    }
  }
}

