{
  "index_patterns": [
    "zeebe-record_process-instance-business-id_*"
  ],
  "composed_of": [
    "zeebe-record"
  ],
  "priority": 20,
  "version": 1,
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 1,
      "index.queries.cache.enabled": false
    },
    "aliases": {
      "zeebe-record-process-instance-business-id": {}
    },
    "mappings": {
      "properties": {
        "value": {
          "dynamic": "strict",
          "properties": {
            "processInstanceKey": {
              "type": "long"
            },
            "businessId": {
              "type": "keyword"
            },
            "processDefinitionKey": {
              "type": "long"
            },
            "rootProcessInstanceKey": {
              "type": "long"
            },
            "bpmnProcessId": {
              "type": "keyword"
            },
            "tenantId": {
              "type": "keyword"
            },
            "elementInstanceKey": {
              "enabled": false
            }
          }
        }
      }
    }
  }
}

