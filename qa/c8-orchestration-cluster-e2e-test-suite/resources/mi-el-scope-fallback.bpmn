<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
  xmlns:modeler="http://camunda.org/schema/modeler/1.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  id="Definitions_scope_fallback"
  targetNamespace="http://bpmn.io/schema/bpmn"
  exporter="Camunda Modeler"
  exporterVersion="5.x"
  modeler:executionPlatform="Camunda Cloud"
  modeler:executionPlatformVersion="8.10.0">

  <!--
    E2E-11 — beforeAll scope fallback (process-level variable inheritance)
    ───────────────────────────────────────────────────────────────────────
    Purpose : Verify that when beforeAll completes WITHOUT setting a variable
              that inputCollection references, the MI body scope correctly
              inherits the pre-existing process-level value (scope fallback /
              upward inheritance).

    Scenario:
      - "count" = 3 is set at process instantiation (process scope)
      - beforeAll fires and completes with NO variables (does not touch "count")
      - inputCollection = "= for i in 1..count return i"
        → MI body scope has no local "count" → inherits process-level count = 3
        → 3 inner instances are created

    Workers required
      mi-scope-fallback-init  – beforeAll job; completes with empty variables {}
      mi-scope-fallback-inner – task job per inner instance
  -->

  <bpmn:process id="mi-el-scope-fallback"
                name="MI EL — Scope Fallback (process var inheritance)"
                isExecutable="true">

    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_start_to_mi</bpmn:outgoing>
    </bpmn:startEvent>

    <!--
      beforeAll  → "mi-scope-fallback-init"
        completes with: {} (intentionally no variables — does not set "count")
      inputCollection references "count" which lives at process scope only.
      Expected: MI body inherits count=3 from process scope → 3 instances.
    -->
    <bpmn:serviceTask id="miTask"
                      name="MI Task (beforeAll does not set count)">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="mi-scope-fallback-inner" retries="3" />
        <zeebe:executionListeners>
          <zeebe:executionListener eventType="beforeAll"
                                   type="mi-scope-fallback-init"
                                   retries="3" />
        </zeebe:executionListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_start_to_mi</bpmn:incoming>
      <bpmn:outgoing>Flow_mi_to_end</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics isSequential="false">
        <bpmn:extensionElements>
          <!--
            "count" is NOT set by beforeAll — resolved via upward scope inheritance
            from the process-level variable set at instantiation.
          -->
          <zeebe:loopCharacteristics
            inputCollection="= for i in 1..count return i"
            inputElement="i" />
        </bpmn:extensionElements>
      </bpmn:multiInstanceLoopCharacteristics>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_mi_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_start_to_mi"
      sourceRef="StartEvent_1" targetRef="miTask" />
    <bpmn:sequenceFlow id="Flow_mi_to_end"
      sourceRef="miTask"       targetRef="EndEvent_1" />

  </bpmn:process>

  <!-- ── Diagram layout (minimal) ─────────────────────────────────────────── -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="mi-el-scope-fallback">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="152" y="82" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="158" y="125" width="24" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="miTask_di" bpmnElement="miTask" isMarkerVisible="true">
        <dc:Bounds x="240" y="60" width="230" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="522" y="82" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="530" y="125" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_start_to_mi_di" bpmnElement="Flow_start_to_mi">
        <di:waypoint x="188" y="100" /><di:waypoint x="240" y="100" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_mi_to_end_di" bpmnElement="Flow_mi_to_end">
        <di:waypoint x="470" y="100" /><di:waypoint x="522" y="100" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
