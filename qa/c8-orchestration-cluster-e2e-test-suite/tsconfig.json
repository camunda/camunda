{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "5.0",
    "baseUrl": "./",
    "noEmit": true,
    "paths": {
      "@fixtures": ["fixtures.ts"],
      "@setup": ["./test-setup.ts"],
      "@pages/*": ["pages/*"],
      "@requestHelpers": ["utils/requestHelpers/index.ts"]
    }
  },
  "exclude": [
    "v2-stateless-tests/request-validation-test-generator/scripts/**"
  ]
}
