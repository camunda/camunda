### =============================================
### PHASE 4: Handle Happy Path test (validate + complete)
### =============================================


### Step 6: Validate Happy Path user task
# @name get-happy-task-details
GET {{ZEEBE_REST_ADDRESS}}/v2/user-tasks/{{HAPPY_TASK_KEY}}
Authorization: {{AUTH_TYPE}} {{AUTH_TOKEN}}
Accept: application/json

> {%
  client.test("[Happy Path] Get user task is successful", function () {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });

  client.test("[Happy Path] User task belongs to correct process instance", function () {
    const expectedKey = client.global.get("PI_KEY_HAPPY");
    client.assert(String(response.body.processInstanceKey) === String(expectedKey),
      "processInstanceKey mismatch. Expected " + expectedKey + " got " + response.body.processInstanceKey);
  });
%}


### Step 7: Validate AI agent response variable (Happy Path)
# @name search-happy-agent-variable
POST {{ZEEBE_REST_ADDRESS}}/v2/variables/search
Authorization: {{AUTH_TYPE}} {{AUTH_TOKEN}}
Content-Type: application/json
Accept: application/json

{
  "filter": {
    "processInstanceKey": "{{PI_KEY_HAPPY}}",
    "name": "agent"
  },
  "page": { "from": 0, "limit": 10 }
}

> {%
  client.test("[Happy Path] Variable search is successful", function () {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });

  client.test("[Happy Path] Agent variable exists", function () {
    client.assert(response.body.items && response.body.items.length > 0,
      "No 'agent' variable found for the process instance");
    client.global.set("HAPPY_AGENT_VAR_KEY", response.body.items[0].variableKey);
  });
%}


### Step 7b: Fetch and validate AI response content (Happy Path)
# @name get-happy-agent-variable
GET {{ZEEBE_REST_ADDRESS}}/v2/variables/{{HAPPY_AGENT_VAR_KEY}}
Authorization: {{AUTH_TYPE}} {{AUTH_TOKEN}}
Accept: application/json

> {%
  client.test("[Happy Path] Get variable is successful", function () {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });

  client.test("[Happy Path] Agent response contains responseText", function () {
    const value = typeof response.body.value === "string" ? JSON.parse(response.body.value) : response.body.value;
    client.assert(value.responseText !== undefined && value.responseText !== null,
      "agent.responseText is missing");
    client.assert(value.responseText.length > 0,
      "agent.responseText is empty");
    client.log("[Happy Path] AI Agent response: " + value.responseText.substring(0, 200));
  });
%}


### Step 8: Assign and complete Happy Path user task (satisfied)
# @name assign-happy-task
POST {{ZEEBE_REST_ADDRESS}}/v2/user-tasks/{{HAPPY_TASK_KEY}}/assignment
Authorization: {{AUTH_TYPE}} {{AUTH_TOKEN}}
Content-Type: application/json
Accept: application/json

{
  "assignee": "demo",
  "allowOverride": true,
  "action": "assign"
}

> {%
  client.test("[Happy Path] Assign user task is successful", function () {
    client.assert(response.status === 204, "Expected 204, got " + response.status);
  });
%}


### Step 8b: Complete Happy Path user task with userSatisfied=true
# @name complete-happy-task
POST {{ZEEBE_REST_ADDRESS}}/v2/user-tasks/{{HAPPY_TASK_KEY}}/completion
Authorization: {{AUTH_TYPE}} {{AUTH_TOKEN}}
Content-Type: application/json
Accept: application/json

{
  "variables": {
    "userSatisfied": true
  },
  "action": "complete"
}

> {%
  client.test("[Happy Path] Complete user task is successful", function () {
    client.assert(response.status === 204, "Expected 204, got " + response.status);
  });
%}


### =============================================
### PHASE 5: Handle Feedback Loop test (reject + re-process + accept)
### =============================================


### Step 9: Assign and reject Feedback Loop user task (not satisfied)
# @name assign-feedback-task
POST {{ZEEBE_REST_ADDRESS}}/v2/user-tasks/{{FEEDBACK_TASK_KEY}}/assignment
Authorization: {{AUTH_TYPE}} {{AUTH_TOKEN}}
Content-Type: application/json
Accept: application/json

{
  "assignee": "demo",
  "allowOverride": true,
  "action": "assign"
}

> {%
  client.test("[Feedback Loop] Assign user task is successful", function () {
    client.assert(response.status === 204, "Expected 204, got " + response.status);
  });
%}


### Step 9b: Reject AI response with feedback
# @name reject-feedback-task
POST {{ZEEBE_REST_ADDRESS}}/v2/user-tasks/{{FEEDBACK_TASK_KEY}}/completion
Authorization: {{AUTH_TYPE}} {{AUTH_TOKEN}}
Content-Type: application/json
Accept: application/json

{
  "variables": {
    "userSatisfied": false,
    "followUpInput": "The response is too vague. Please provide more specific details and include concrete examples."
  },
  "action": "complete"
}

> {%
  client.test("[Feedback Loop] Reject AI response is successful", function () {
    client.assert(response.status === 204, "Expected 204, got " + response.status);
  });
%}


### Step 10a: Wait for AI Agent to re-process + Search new user task (attempt 1)
# @name search-loop-task-attempt-1
< {%
  import {wait} from "../js/wait"
  wait(20)
%}
POST {{ZEEBE_REST_ADDRESS}}/v2/user-tasks/search
Authorization: {{AUTH_TYPE}} {{AUTH_TOKEN}}
Content-Type: application/json
Accept: application/json

{
  "filter": {
    "processInstanceKey": "{{PI_KEY_FEEDBACK}}",
    "state": "CREATED"
  },
  "page": { "from": 0, "limit": 10 }
}

> {%
  client.test("[Feedback Loop] User task search after rejection (attempt 1) is successful", function () {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });

  if (response.body.items && response.body.items.length > 0) {
    const newTaskKey = response.body.items[0].userTaskKey;
    const previousTaskKey = client.global.get("FEEDBACK_TASK_KEY");
    if (String(newTaskKey) !== String(previousTaskKey)) {
      client.global.set("LOOP_TASK_FOUND", "true");
      client.global.set("LOOP_TASK_KEY", newTaskKey);
      client.log("[Feedback Loop] New task found on attempt 1: " + newTaskKey);
    } else {
      client.global.set("LOOP_TASK_FOUND", "false");
      client.log("[Feedback Loop] Same task key as before, AI still processing...");
    }
  } else {
    client.global.set("LOOP_TASK_FOUND", "false");
    client.log("[Feedback Loop] No task found on attempt 1, will retry...");
  }
%}


### Step 10b: Wait + Search new user task after loop (attempt 2)
# @name search-loop-task-attempt-2
< {%
  import {wait} from "../js/wait"
  const found = client.global.get("LOOP_TASK_FOUND");
  if (found !== "true") {
    wait(20)
  }
%}
POST {{ZEEBE_REST_ADDRESS}}/v2/user-tasks/search
Authorization: {{AUTH_TYPE}} {{AUTH_TOKEN}}
Content-Type: application/json
Accept: application/json

{
  "filter": {
    "processInstanceKey": "{{PI_KEY_FEEDBACK}}",
    "state": "CREATED"
  },
  "page": { "from": 0, "limit": 10 }
}

> {%
  const alreadyFound = client.global.get("LOOP_TASK_FOUND");
  if (alreadyFound === "true") {
    client.test("[Feedback Loop] User task search after rejection (attempt 2) - skipped", function () {
      client.assert(true, "Skipped");
    });
  } else {
    client.test("[Feedback Loop] User task search after rejection (attempt 2) is successful", function () {
      client.assert(response.status === 200, "Expected 200, got " + response.status);
    });

    if (response.body.items && response.body.items.length > 0) {
      const newTaskKey = response.body.items[0].userTaskKey;
      const previousTaskKey = client.global.get("FEEDBACK_TASK_KEY");
      if (String(newTaskKey) !== String(previousTaskKey)) {
        client.global.set("LOOP_TASK_FOUND", "true");
        client.global.set("LOOP_TASK_KEY", newTaskKey);
        client.log("[Feedback Loop] New task found on attempt 2: " + newTaskKey);
      } else {
        client.global.set("LOOP_TASK_FOUND", "false");
        client.log("[Feedback Loop] Same task key as before, AI still processing...");
      }
    } else {
      client.global.set("LOOP_TASK_FOUND", "false");
      client.log("[Feedback Loop] No task found on attempt 2, will retry...");
    }
  }
%}


### Step 10c: Wait + Search new user task after loop (attempt 3 - final)
# @name search-loop-task-attempt-3
< {%
  import {wait} from "../js/wait"
  const found = client.global.get("LOOP_TASK_FOUND");
  if (found !== "true") {
    wait(20)
  }
%}
POST {{ZEEBE_REST_ADDRESS}}/v2/user-tasks/search
Authorization: {{AUTH_TYPE}} {{AUTH_TOKEN}}
Content-Type: application/json
Accept: application/json

{
  "filter": {
    "processInstanceKey": "{{PI_KEY_FEEDBACK}}",
    "state": "CREATED"
  },
  "page": { "from": 0, "limit": 10 }
}

> {%
  const alreadyFound = client.global.get("LOOP_TASK_FOUND");
  if (alreadyFound === "true") {
    client.test("[Feedback Loop] User task search after rejection (attempt 3) - skipped", function () {
      client.assert(true, "Skipped");
    });
  } else {
    client.test("[Feedback Loop] User task search after rejection (attempt 3) is successful", function () {
      client.assert(response.status === 200, "Expected 200, got " + response.status);
    });

    client.test("[Feedback Loop] New user task should exist after feedback loop", function () {
      client.assert(response.body.items && response.body.items.length > 0,
        "No new user task found after feedback loop (~60s). The AI Agent may have failed to re-process after rejection.");
      const newTaskKey = response.body.items[0].userTaskKey;
      const previousTaskKey = client.global.get("FEEDBACK_TASK_KEY");
      client.assert(String(newTaskKey) !== String(previousTaskKey),
        "Expected a NEW user task after feedback loop, but got the same task key: " + newTaskKey);
      client.global.set("LOOP_TASK_FOUND", "true");
      client.global.set("LOOP_TASK_KEY", newTaskKey);
      client.log("[Feedback Loop] New task found on attempt 3: " + newTaskKey);
    });
  }
%}


