    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });

  client.test("[Feedback Loop] Process instance is COMPLETED after feedback loop", function () {
    client.assert(response.body.state === "COMPLETED",
      "Expected state COMPLETED but got " + response.body.state);
    client.log("[Feedback Loop] Process instance " + response.body.processInstanceKey + " completed successfully after feedback loop");
  });
