### =============================================
### AI Agent Connector E2E Tests (OpenAI)
### =============================================
### Uses interleaved execution: all process instances start together so AI Agent
### invocations run in parallel during the same wait window.
###
### @test Happy Path - user accepts AI response on first attempt
### @test Feedback Loop - user rejects, AI re-processes, user accepts


### =============================================
### PHASE 1: Setup (auth + deploy)
### =============================================


### Step 1: Get Bearer token (Keycloak client_credentials)
# @name get-bearer-token
POST {{CAMUNDA_OAUTH_URL}}
Content-Type: application/x-www-form-urlencoded

    client_id={{CLIENT_ID}}
    &client_secret={{CLIENT_SECRET}}
    &grant_type=client_credentials

> {%
  client.test("Get token should be successful", function () {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
    client.global.set("AUTH_TOKEN", response.body.access_token);
  });
%}


### Step 2: Deploy BPMN and Form together
# @name deploy-ai-agent-resources
< {%
  import {wait} from "../js/wait"
  wait(2)
%}
POST {{ZEEBE_REST_ADDRESS}}/v2/deployments
Authorization: {{AUTH_TYPE}} {{AUTH_TOKEN}}
Accept: application/json
Content-Type: multipart/form-data; boundary=boundary123

--boundary123
Content-Disposition: form-data; name="tenantId"
Content-Type: application/json

<default>
--boundary123
Content-Disposition: form-data; name="resources"; filename="ai-agent-chat-user-feedback.form"
Content-Type: application/octet-stream

< ./resources/ai-agent-chat-user-feedback.form
--boundary123
Content-Disposition: form-data; name="resources"; filename="ai-agent-chat-with-tools_open_ai.bpmn"
Content-Type: application/octet-stream

< ./resources/ai-agent-chat-with-tools_open_ai.bpmn
--boundary123--

> {%
  client.test("Deployment is successful", function () {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });

  client.test("Response contains process definition", function () {
    const deployments = response.body.deployments;
    client.assert(Array.isArray(deployments), "deployments must be an array");
    client.assert(deployments.length >= 1, "Expected at least 1 deployment");

    let processDefKey = null;
    for (let i = 0; i < deployments.length; i++) {
      if (deployments[i].processDefinition) {
        processDefKey = deployments[i].processDefinition.processDefinitionKey;
        break;
      }
    }
    client.assert(processDefKey !== null, "No process definition found in deployments");
    client.global.set("PROCESS_DEFINITION_KEY", processDefKey);
    client.log("Process definition key: " + processDefKey);
  });
%}


### =============================================
### PHASE 2: Start ALL process instances (AI Agents process in parallel)
### =============================================


### Step 3: Start process instance for Happy Path test
# @name start-instance-happy-path
POST {{ZEEBE_REST_ADDRESS}}/v2/process-instances
Authorization: {{AUTH_TYPE}} {{AUTH_TOKEN}}
Content-Type: application/json
Accept: application/json

{
  "processDefinitionKey": "{{PROCESS_DEFINITION_KEY}}",
  "variables": {},
  "tenantId": "<default>"
}

> {%
  client.test("[Happy Path] Process instance creation is successful", function () {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });

  client.test("[Happy Path] Response contains process instance key", function () {
    client.assert(response.body.processInstanceKey !== undefined, "processInstanceKey not found");
    client.global.set("PI_KEY_HAPPY", response.body.processInstanceKey);
    client.log("[Happy Path] Process instance key: " + response.body.processInstanceKey);
  });
%}


### Step 4: Start process instance for Feedback Loop test
# @name start-instance-feedback-loop
POST {{ZEEBE_REST_ADDRESS}}/v2/process-instances
Authorization: {{AUTH_TYPE}} {{AUTH_TOKEN}}
Content-Type: application/json
Accept: application/json

{
  "processDefinitionKey": "{{PROCESS_DEFINITION_KEY}}",
  "variables": {},
  "tenantId": "<default>"
}

> {%
  client.test("[Feedback Loop] Process instance creation is successful", function () {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });

  client.test("[Feedback Loop] Response contains process instance key", function () {
    client.assert(response.body.processInstanceKey !== undefined, "processInstanceKey not found");
    client.global.set("PI_KEY_FEEDBACK", response.body.processInstanceKey);
    client.log("[Feedback Loop] Process instance key: " + response.body.processInstanceKey);
  });
%}


### =============================================
### PHASE 3: Wait for BOTH AI Agents to complete (shared wait)
### Both AI Agent connectors are now processing in parallel.
### We wait once, then check both.
### =============================================


### Step 5a: Wait for AI Agents + Search Happy Path user task (attempt 1)
# @name search-happy-task-attempt-1
< {%
  import {wait} from "../js/wait"
  wait(20)
%}
POST {{ZEEBE_REST_ADDRESS}}/v2/user-tasks/search
Authorization: {{AUTH_TYPE}} {{AUTH_TOKEN}}
Content-Type: application/json
Accept: application/json

{
  "filter": {
    "processInstanceKey": "{{PI_KEY_HAPPY}}",
    "state": "CREATED"
  },
  "page": { "from": 0, "limit": 10 }
}

> {%
  client.test("[Happy Path] User task search (attempt 1) is successful", function () {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });

  if (response.body.items && response.body.items.length > 0) {
    client.global.set("HAPPY_TASK_FOUND", "true");
    client.global.set("HAPPY_TASK_KEY", response.body.items[0].userTaskKey);
    client.log("[Happy Path] Task found on attempt 1: " + response.body.items[0].userTaskKey);
  } else {
    client.global.set("HAPPY_TASK_FOUND", "false");
    client.log("[Happy Path] No task found on attempt 1, will retry...");
  }
%}


### Step 5b: Search Feedback Loop user task (attempt 1 - no extra wait, same window)
# @name search-feedback-task-attempt-1
POST {{ZEEBE_REST_ADDRESS}}/v2/user-tasks/search
Authorization: {{AUTH_TYPE}} {{AUTH_TOKEN}}
Content-Type: application/json
Accept: application/json

{
  "filter": {
    "processInstanceKey": "{{PI_KEY_FEEDBACK}}",
    "state": "CREATED"
  },
  "page": { "from": 0, "limit": 10 }
}

> {%
  client.test("[Feedback Loop] User task search (attempt 1) is successful", function () {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });

  if (response.body.items && response.body.items.length > 0) {
    client.global.set("FEEDBACK_TASK_FOUND", "true");
    client.global.set("FEEDBACK_TASK_KEY", response.body.items[0].userTaskKey);
    client.log("[Feedback Loop] Task found on attempt 1: " + response.body.items[0].userTaskKey);
  } else {
    client.global.set("FEEDBACK_TASK_FOUND", "false");
    client.log("[Feedback Loop] No task found on attempt 1, will retry...");
  }
%}


### Step 5c: Retry wait + Search Happy Path user task (attempt 2)
# @name search-happy-task-attempt-2
< {%
  import {wait} from "../js/wait"
  const happyFound = client.global.get("HAPPY_TASK_FOUND");
  const feedbackFound = client.global.get("FEEDBACK_TASK_FOUND");
  if (happyFound !== "true" || feedbackFound !== "true") {
    wait(20)
  }
%}
POST {{ZEEBE_REST_ADDRESS}}/v2/user-tasks/search
Authorization: {{AUTH_TYPE}} {{AUTH_TOKEN}}
Content-Type: application/json
Accept: application/json

{
  "filter": {
    "processInstanceKey": "{{PI_KEY_HAPPY}}",
    "state": "CREATED"
  },
  "page": { "from": 0, "limit": 10 }
}

> {%
  const alreadyFound = client.global.get("HAPPY_TASK_FOUND");
  if (alreadyFound === "true") {
    client.test("[Happy Path] User task search (attempt 2) - skipped, already found", function () {
      client.assert(true, "Skipped");
    });
  } else {
    client.test("[Happy Path] User task search (attempt 2) is successful", function () {
      client.assert(response.status === 200, "Expected 200, got " + response.status);
    });

    if (response.body.items && response.body.items.length > 0) {
      client.global.set("HAPPY_TASK_FOUND", "true");
      client.global.set("HAPPY_TASK_KEY", response.body.items[0].userTaskKey);
      client.log("[Happy Path] Task found on attempt 2: " + response.body.items[0].userTaskKey);
    } else {
      client.global.set("HAPPY_TASK_FOUND", "false");
      client.log("[Happy Path] No task found on attempt 2, will retry...");
    }
  }
%}


