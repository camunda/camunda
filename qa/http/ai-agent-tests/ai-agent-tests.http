### =============================================
### PHASE 6: Assert BOTH process instances completed
### =============================================


### Step 12: Assert Happy Path process instance is COMPLETED
# @name assert-happy-path-completed
< {%
  import {wait} from "../js/wait"
  wait(10)
%}
GET {{ZEEBE_REST_ADDRESS}}/v2/process-instances/{{PI_KEY_HAPPY}}
Authorization: {{AUTH_TYPE}} {{AUTH_TOKEN}}
Accept: application/json

> {%
  client.test("[Happy Path] Get process instance is successful", function () {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });

  client.test("[Happy Path] Process instance is COMPLETED", function () {
    client.assert(response.body.state === "COMPLETED",
      "Expected state COMPLETED but got " + response.body.state);
    client.log("[Happy Path] Process instance " + response.body.processInstanceKey + " completed successfully");
  });
%}


### Step 12b: Assert Feedback Loop process instance is COMPLETED
