### Step 5e: Retry wait + Search Happy Path user task (attempt 3 - final)
# @name search-happy-task-attempt-3
< {%
  import {wait} from "../js/wait"
  const happyFound = client.global.get("HAPPY_TASK_FOUND");
  const feedbackFound = client.global.get("FEEDBACK_TASK_FOUND");
  if (happyFound !== "true" || feedbackFound !== "true") {
    wait(20)
  }
%}
POST {{ZEEBE_REST_ADDRESS}}/v2/user-tasks/search
Authorization: {{AUTH_TYPE}} {{AUTH_TOKEN}}
Content-Type: application/json
Accept: application/json

{
  "filter": {
    "processInstanceKey": "{{PI_KEY_HAPPY}}",
    "state": "CREATED"
  },
  "page": { "from": 0, "limit": 10 }
}

> {%
  const alreadyFound = client.global.get("HAPPY_TASK_FOUND");
  if (alreadyFound === "true") {
    client.test("[Happy Path] User task search (attempt 3) - skipped, already found", function () {
      client.assert(true, "Skipped");
    });
  } else {
    client.test("[Happy Path] User task search (attempt 3) is successful", function () {
      client.assert(response.status === 200, "Expected 200, got " + response.status);
    });

    client.test("[Happy Path] User task should exist after 3 attempts", function () {
      client.assert(response.body.items && response.body.items.length > 0,
        "No user task found after 3 search attempts (~60s). The AI Agent connector may have failed or timed out.");
      client.global.set("HAPPY_TASK_FOUND", "true");
      client.global.set("HAPPY_TASK_KEY", response.body.items[0].userTaskKey);
      client.log("[Happy Path] Task found on attempt 3: " + response.body.items[0].userTaskKey);
    });
  }
%}


