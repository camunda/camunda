### Search Users for Tenant
# @name search-users-for-tenant
POST {{ZEEBE_REST_ADDRESS_LOCAL}}/v2/tenants/{{CONFIGURED_TENANT_ID}}/users/search
Authorization: Bearer {{TOKEN}}
Content-Type: application/json
Accept: application/json

{
  "sort": [
    { "field": "username", "order": "ASC" }
  ],
  "page": { "from": 0, "limit": 100 }
}

> {%
  client.test("Users search should be successful", function () {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });

  client.test("Response should be JSON", function () {
    client.assert(response.headers.valueOf("Content-Type").includes("application/json"), "Response is not JSON");
  });

  client.test("All configured users should be returned", function () {
    client.assert(response.status === 200, "Expected 200, got " + response.status);

    const expectedUsers =["UserA", "UserB", "UserC", "demo", "test"];
    let returnedUsers = response.body.items.map(u => u.username);

    expectedUsers.forEach(u => {
      client.assert(returnedUsers.includes(u), "Expected user '" + u + "' not found in tenant");
    });
  });
%}

### Search Groups for Tenant
# @name search-groups-for-tenant
POST {{ZEEBE_REST_ADDRESS_LOCAL}}/v2/tenants/{{CONFIGURED_TENANT_ID}}/groups/search
Authorization: Bearer {{TOKEN}}
Content-Type: application/json
Accept: application/json

{
  "sort": [
    { "field": "groupId", "order": "ASC" }
  ],
  "page": { "from": 0, "limit": 100 }
}

> {%
  client.test("Groups search should be successful", function () {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });

  client.test("Response should be JSON", function () {
    client.assert(response.headers.valueOf("Content-Type").includes("application/json"), "Response is not JSON");
  });

  client.test("All configured groups should be returned", function () {
    client.assert(response.status === 200, "Expected 200, got " + response.status);

    const expectedGroups =["R4GR", "adminGr", "connectorsGr", "test-config-group"];
    let returnedGroups = response.body.items.map(g => g.groupId);

    expectedGroups.forEach(g => {
      client.assert(returnedGroups.includes(g), "Expected group '" + g + "' not found in tenant");
    });
  });
%}

### Search Roles for Tenant
# @name search-roles-for-tenant
POST {{ZEEBE_REST_ADDRESS_LOCAL}}/v2/tenants/{{CONFIGURED_TENANT_ID}}/roles/search
Authorization: Bearer {{TOKEN}}
Content-Type: application/json
Accept: application/json

{
  "sort": [
    { "field": "roleId", "order": "ASC" }
  ],
  "page": { "from": 0, "limit": 100 }
}

> {%
  client.test("Roles search should be successful", function () {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });

  client.test("Response should be JSON", function () {
    client.assert(response.headers.valueOf("Content-Type").includes("application/json"), "Response is not JSON");
  });

  client.test("All configured roles should be returned", function () {
    client.assert(response.status === 200, "Expected 200, got " + response.status);

    const expectedRoles =["admin", "connectors", "test-config-role"];
    const notExistentRole ="R4";
    let returnedRoles = response.body.items.map(r => r.roleId);

    expectedRoles.forEach(r => {
      client.assert(returnedRoles.includes(r), "Expected role '" + r + "' not found in tenant");
    });
    client.assert(
        !returnedRoles.includes(notExistentRole),
        "Non-existent role '" + notExistentRole + "' should NOT be returned"
    );
  });
%}

