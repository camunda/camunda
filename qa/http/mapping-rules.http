### Search Mapping Rules for Tenant
# @name search-mapping-rules-for-tenant
POST {{ZEEBE_REST_ADDRESS_LOCAL}}/v2/tenants/{{CONFIGURED_TENANT_ID}}/mapping-rules/search
Authorization: Bearer {{TOKEN}}
Content-Type: application/json
Accept: application/json

{
  "sort": [
    { "field": "mappingRuleId", "order": "ASC" }
  ],
  "page": { "from": 0, "limit": 100 }
}

> {%
  client.test("Mapping Rules search should be successful", function () {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });

  client.test("Response should be JSON", function () {
    client.assert(response.headers.valueOf("Content-Type").includes("application/json"), "Response is not JSON");
  });

  client.test("None of the non-existent mapping rules should be returned", function () {
    const nonExistentMappings = ["M1", "m2", "m."];
    const returnedMappings = response.body.items.map(m => m.mappingRuleId);

    nonExistentMappings.forEach(m => {
      client.assert(
          !returnedMappings.includes(m),
          "Non-existent mapping rule '" + m + "' was unexpectedly returned"
      );
    });
  });
%}

