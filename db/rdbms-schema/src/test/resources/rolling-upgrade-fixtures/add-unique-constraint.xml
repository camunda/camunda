<!--suppress LiquibaseXmlUnresolvedProperty -->
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <!-- Unsafe: add a UNIQUE constraint on an existing write-path column -->
  <changeSet id="add_unique_constraint" author="camunda">
    <addUniqueConstraint tableName="PROCESS_INSTANCE" columnNames="STATE"
      constraintName="UQ_PROCESS_INSTANCE_STATE"/>
  </changeSet>

</databaseChangeLog>
