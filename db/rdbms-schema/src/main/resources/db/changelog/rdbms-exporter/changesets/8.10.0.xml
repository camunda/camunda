<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="add_message_subscription_type_and_process_definition_fields" author="camunda">
    <addColumn tableName="${prefix}MESSAGE_SUBSCRIPTION">
      <column name="MESSAGE_SUBSCRIPTION_TYPE" type="VARCHAR(50)"/>
      <column name="PROCESS_DEFINITION_NAME" type="VARCHAR(${userCharColumnSize})"/>
      <column name="PROCESS_DEFINITION_VERSION" type="INTEGER"/>
    </addColumn>

    <createIndex tableName="${prefix}MESSAGE_SUBSCRIPTION"
      indexName="${prefix}IDX_MESSAGE_SUBSCRIPTION_TYPE">
      <column name="MESSAGE_SUBSCRIPTION_TYPE"/>
    </createIndex>
  </changeSet>

  <changeSet id="add_message_subscription_extension_properties" author="camunda">
    <addColumn tableName="${prefix}MESSAGE_SUBSCRIPTION">
      <column name="EXTENSION_PROPERTIES" type="CLOB"/>
    </addColumn>
  </changeSet>

</databaseChangeLog>
