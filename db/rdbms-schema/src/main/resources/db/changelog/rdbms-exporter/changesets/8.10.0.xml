<!--suppress LiquibaseXmlUnresolvedProperty -->
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
  <property name="timestampWithTimeZone.type" value="DATETIMEOFFSET" dbms="mssql"/>

  <changeSet id="create_deployed_resource_table" author="camunda">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="${prefix}DEPLOYED_RESOURCE"/>
      </not>
    </preConditions>
    <createTable tableName="${prefix}DEPLOYED_RESOURCE">
      <column name="RESOURCE_KEY" type="BIGINT">
        <constraints primaryKey="true"/>
      </column>
      <column name="RESOURCE_ID" type="NVARCHAR(${userCharColumnSize})"/>
      <column name="RESOURCE_NAME" type="NVARCHAR(${userCharColumnSize})"/>
      <column name="VERSION" type="SMALLINT"/>
      <column name="VERSION_TAG" type="NVARCHAR(${userCharColumnSize})"/>
      <column name="DEPLOYMENT_KEY" type="BIGINT"/>
      <column name="TENANT_ID" type="NVARCHAR(${userCharColumnSize})"/>
      <column name="RESOURCE_CONTENT" type="CLOB"/>
    </createTable>
  </changeSet>

  <changeSet id="create_process_instance_end_date_index" author="camunda" context="async" runInTransaction="false">
    <!-- Index for ACTOR_ID - optimizes querying audit log entries by actor -->
    <preConditions onFail="MARK_RAN">
      <not>
        <indexExists indexName="${prefix}IDX_PROCESS_INSTANCE_END_DATE" tableName="${prefix}PROCESS_INSTANCE"/>
      </not>
    </preConditions>

    <sql dbms="h2">
      CREATE INDEX ${prefix}IDX_PROCESS_INSTANCE_END_DATE ON PROCESS_INSTANCE (END_DATE)
    </sql>

    <sql dbms="postgresql">
      CREATE INDEX CONCURRENTLY ${prefix}IDX_PROCESS_INSTANCE_END_DATE ON PROCESS_INSTANCE (END_DATE)
    </sql>

    <sql dbms="mssql">
      CREATE INDEX ${prefix}IDX_PROCESS_INSTANCE_END_DATE ON PROCESS_INSTANCE (END_DATE) WITH (ONLINE = ON)
    </sql>

    <sql dbms="oracle">
      ALTER TABLE ${prefix}IDX_PROCESS_INSTANCE_END_DATE
        ADD INDEX PROCESS_INSTANCE (END_DATE)
        ALGORITHM=INPLACE,
        LOCK=NONE
    </sql>
  </changeSet>

</databaseChangeLog>
