<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.camunda.db.rdbms.sql.ReplicationStatusMapper">

  <resultMap id="replicationLogStatusResultMap" type="io.camunda.db.rdbms.read.replication.ReplicationLogStatus">
    <constructor>
      <arg column="logStatus" javaType="java.lang.Long"/>
      <arg column="replicaId" javaType="java.lang.String"/>
      <arg column="replicationLagMs" javaType="java.lang.Long"/>
    </constructor>
  </resultMap>

  <select id="getCurrentLogStatus" resultType="java.lang.Long" databaseId="postgresql">
    SELECT pg_wal_lsn_diff(pg_current_wal_lsn(), '0/0')::bigint last_lsn
  </select>

  <select id="getReplicationStatus" resultMap="replicationLogStatusResultMap" databaseId="postgresql">
    SELECT
      COALESCE(pg_wal_lsn_diff(replay_lsn, '0/0'), 0)::bigint AS logStatus,
      pid::text AS replicaId,
      COALESCE((EXTRACT(EPOCH FROM replay_lag) * 1000)::bigint, 0) AS replicationLagMs
    FROM pg_stat_replication
    WHERE pid IS NOT NULL;
  </select>

  <!--
    MSSQL: last_commit_lsn are numeric(25,0) in sys.dm_hadr_database_replica_states,
    directly comparable as bigint for a test/dev database where LSN values stay small.
    last_redone_time approximates lag as "time since last redo applied on replica".
  -->
  <select id="getCurrentLogStatus" resultType="java.lang.Long" databaseId="mssql">
    SELECT CONVERT(bigint, last_commit_lsn) AS last_lsn
    FROM sys.dm_hadr_database_replica_states
    WHERE is_local = 1
  </select>

  <select id="getReplicationStatus" resultMap="replicationLogStatusResultMap" databaseId="mssql">
    SELECT
      CONVERT(bigint, ISNULL(last_commit_lsn, 0))                      AS logStatus,
      CONVERT(nvarchar(36), replica_id)                                 AS replicaId,
      ISNULL(DATEDIFF(millisecond, last_redone_time, GETDATE()), 0)    AS replicationLagMs
    FROM sys.dm_hadr_database_replica_states
    WHERE is_local = 0
  </select>

  <!--
    Detects whether the connected PostgreSQL instance is actually AWS Aurora. The check looks up
    the aurora_global_db_instance_status function in pg_proc without invoking it, so it is safe
    to run on any PostgreSQL-compatible database. Returns true only on Aurora.
  -->
  <select id="isAurora" resultType="boolean" databaseId="postgresql">
    SELECT EXISTS(
      SELECT 1 FROM pg_proc WHERE proname = 'aurora_global_db_instance_status'
    )
  </select>

  <!--
    Detects whether the connected MySQL instance is AWS Aurora MySQL. Aurora MySQL exposes the
    aurora_version system variable; plain MySQL does not. Querying
    performance_schema.global_variables is safe on any MySQL-compatible database.
  -->
  <select id="isAurora" resultType="boolean" databaseId="mysql">
    SELECT EXISTS(
      SELECT 1 FROM performance_schema.global_variables WHERE variable_name = 'aurora_version'
    )
  </select>

  <!--
    Returns the primary's current durable LSN for Aurora Global Database (PostgreSQL).
    The row with session_id = 'MASTER_SESSION_ID' identifies the primary writer.
  -->
  <select id="getAuroraCurrentLogStatus" resultType="java.lang.Long" databaseId="postgresql">
    SELECT durable_lsn
    FROM aurora_global_db_instance_status()
    WHERE session_id = 'MASTER_SESSION_ID'
  </select>

  <!--
    Returns the primary's current durable LSN for Aurora Global Database (MySQL).
    The row with SESSION_ID = 'MASTER_SESSION_ID' identifies the primary writer.
  -->
  <select id="getAuroraCurrentLogStatus" resultType="java.lang.Long" databaseId="mysql">
    SELECT DURABLE_LSN
    FROM aurora_global_db_instance_status()
    WHERE SESSION_ID = 'MASTER_SESSION_ID'
  </select>

  <!--
    Returns per-replica replication status for Aurora Global Database (PostgreSQL). Each non-primary
    instance reports its durable_lsn (the LSN persisted to durable storage on that instance)
    together with the visibility_lag_in_msec for metrics.
  -->
  <select id="getAuroraReplicationStatus" resultMap="replicationLogStatusResultMap" databaseId="postgresql">
    SELECT
      durable_lsn                                           AS logStatus,
      server_id                                             AS replicaId,
      COALESCE(visibility_lag_in_msec, 0)                   AS replicationLagMs
    FROM aurora_global_db_instance_status()
    WHERE session_id != 'MASTER_SESSION_ID'
  </select>

  <!--
    Returns per-replica replication status for Aurora Global Database (MySQL). Each non-primary
    instance reports its DURABLE_LSN together with VISIBILITY_LAG_IN_MSEC for metrics.
  -->
  <select id="getAuroraReplicationStatus" resultMap="replicationLogStatusResultMap" databaseId="mysql">
    SELECT
      DURABLE_LSN                                           AS logStatus,
      SERVER_ID                                             AS replicaId,
      COALESCE(VISIBILITY_LAG_IN_MSEC, 0)                   AS replicationLagMs
    FROM aurora_global_db_instance_status()
    WHERE SESSION_ID != 'MASTER_SESSION_ID'
  </select>

</mapper>

