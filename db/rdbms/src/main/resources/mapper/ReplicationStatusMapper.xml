<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.camunda.db.rdbms.sql.ReplicationStatusMapper">

  <resultMap id="replicationLogStatusResultMap"
    type="io.camunda.db.rdbms.read.replication.ReplicationLogStatus">
    <constructor>
      <arg column="logStatus" javaType="java.lang.Long"/>
      <arg column="replicaId" javaType="java.lang.String"/>
      <arg column="replicationLagMs" javaType="java.lang.Long"/>
    </constructor>
  </resultMap>

  <!-- PostgreSQL -->
  <select id="getCurrentLogStatus" resultType="java.lang.Long" databaseId="postgresql">
    SELECT pg_wal_lsn_diff(pg_current_wal_lsn(), '0/0')::bigint last_lsn
  </select>

  <select id="getReplicationStatus" resultMap="replicationLogStatusResultMap"
    databaseId="postgresql">
    SELECT COALESCE(pg_wal_lsn_diff(replay_lsn, '0/0'), 0)::bigint      AS logStatus,
           pid::text                                                    AS replicaId,
           COALESCE((EXTRACT(EPOCH FROM replay_lag) * 1000)::bigint, 0) AS replicationLagMs
    FROM pg_stat_replication
    WHERE pid IS NOT NULL;
  </select>

  <!--
    MSSQL: last_commit_lsn are numeric(25,0) in sys.dm_hadr_database_replica_states,
    directly comparable as bigint for a test/dev database where LSN values stay small.
    last_redone_time approximates lag as "time since last redo applied on replica".
  -->
  <select id="getCurrentLogStatus" resultType="java.lang.Long" databaseId="mssql">
    SELECT CONVERT(bigint, last_commit_lsn) AS last_lsn
    FROM sys.dm_hadr_database_replica_states
    WHERE is_local = 1
  </select>

  <select id="getReplicationStatus" resultMap="replicationLogStatusResultMap" databaseId="mssql">
    SELECT CONVERT(bigint, ISNULL (last_commit_lsn, 0)) AS logStatus,
           CONVERT(nvarchar(36), replica_id)            AS replicaId, ISNULL
      (DATEDIFF(millisecond, last_redone_time, GETDATE()), 0)
      AS replicationLagMs
    FROM sys.dm_hadr_database_replica_states
    WHERE is_local = 0
  </select>

  <!-- Oracle -->
  <select id="getCurrentLogStatus" resultType="java.lang.Long" databaseId="oracle">
    SELECT current_scn FROM v$database
  </select>

  <select id="getReplicationStatus" resultMap="replicationLogStatusResultMap" databaseId="oracle">
    SELECT
      COALESCE(
        (SELECT al.next_change#
         FROM   v$archived_log al
         WHERE  al.sequence# = ad.log_sequence
           AND  al.thread#   = 1
           AND  al.dest_id   = 1
           AND  ROWNUM       = 1),
        0
      )                   AS logStatus,
      TO_CHAR(ad.dest_id) AS replicaId,
      0                   AS replicationLagMs
    FROM v$archive_dest ad
    WHERE ad.target = 'STANDBY'
      AND ad.status NOT IN ('INACTIVE', 'DEFERRED', 'FAILED', 'ERROR', 'BAD PARAM', 'DISABLED')
      AND ad.log_sequence > 0
  </select>

  <!--
    Detects whether the connected PostgreSQL instance is AWS Aurora. Uses to_regprocedure to
    look up aurora_version() in the system catalog — returns null if the function does not exist,
    non-null if it does. Safe to run on any PostgreSQL-compatible database; never throws.
  -->
  <select id="isAurora" resultType="boolean" databaseId="postgresql">
    SELECT to_regprocedure('aurora_version()') IS NOT NULL
  </select>

  <!--
    Detects whether the connected MySQL instance is AWS Aurora MySQL. Aurora MySQL exposes the
    aurora_version() function; plain MySQL does not. Safe to run on any MySQL-compatible database; never throws.
  -->
  <select id="isAurora" resultType="boolean" databaseId="mysql">
    SELECT EXISTS(SELECT 1 FROM information_schema.ROUTINES WHERE ROUTINE_NAME = 'aurora_version')
  </select>

  <!--
    Detects whether the connected Aurora PostgreSQL instance is part of a Global Database.
    Uses to_regprocedure to check for aurora_global_db_instance_status() without calling it.
    Safe to run on any PostgreSQL-compatible database; never throws.
  -->
  <select id="isAuroraGlobalDatabase" resultType="boolean" databaseId="postgresql">
    SELECT to_regprocedure('aurora_global_db_instance_status()') IS NOT NULL
  </select>

  <!--
    Detects whether the connected Aurora MySQL instance is part of a Global Database. Aurora MySQL
    exposes Global Database status as the information_schema.aurora_global_db_instance_status
    table (not a function). Available on Aurora MySQL 3.04.0+ and 8.4+ global databases. Safe to
    run on any MySQL-compatible database; never throws.
  -->
  <select id="isAuroraGlobalDatabase" resultType="boolean" databaseId="mysql">
    SELECT EXISTS(SELECT 1
                  FROM information_schema.TABLES
                  WHERE TABLE_SCHEMA = 'information_schema'
                    AND TABLE_NAME = 'AURORA_GLOBAL_DB_INSTANCE_STATUS')
  </select>

  <!--
    Returns the primary's current durable LSN for Aurora Global Database (PostgreSQL).
    The row with session_id = 'MASTER_SESSION_ID' identifies the primary writer.
  -->
  <select id="getAuroraCurrentLogStatus" resultType="java.lang.Long" databaseId="postgresql">
    SELECT COALESCE(durable_lsn, 0)
    FROM aurora_global_db_instance_status()
    WHERE session_id = 'MASTER_SESSION_ID'
  </select>

  <!--
    Returns the primary's current durable LSN for Aurora Global Database (MySQL). Reads from
    information_schema.aurora_global_db_instance_status (table, not function on MySQL).
    The row with SESSION_ID = 'MASTER_SESSION_ID' identifies the primary writer.
  -->
  <select id="getAuroraCurrentLogStatus" resultType="java.lang.Long" databaseId="mysql">
    SELECT COALESCE(DURABLE_LSN, 0)
    FROM information_schema.aurora_global_db_instance_status
    WHERE SESSION_ID = 'MASTER_SESSION_ID'
  </select>

  <!--
    Returns per-replica replication status for Aurora Global Database (PostgreSQL). Each non-primary
    instance reports its durable_lsn (the LSN persisted to durable storage on that instance)
    together with the visibility_lag_in_msec for metrics.
  -->
  <select id="getAuroraReplicationStatus" resultMap="replicationLogStatusResultMap"
    databaseId="postgresql">
    SELECT COALESCE(durable_lsn, 0)            AS logStatus,
           server_id                           AS replicaId,
           COALESCE(visibility_lag_in_msec, 0) AS replicationLagMs
    FROM aurora_global_db_instance_status()
    WHERE session_id != 'MASTER_SESSION_ID'
  </select>

  <!--
    Returns per-replica replication status for Aurora Global Database (MySQL). Each non-primary
    instance reports its DURABLE_LSN together with VISIBILITY_LAG_IN_MSEC for metrics. Reads from
    information_schema.aurora_global_db_instance_status (table, not function on MySQL).
  -->
  <select id="getAuroraReplicationStatus" resultMap="replicationLogStatusResultMap"
    databaseId="mysql">
    SELECT COALESCE(DURABLE_LSN, 0)            AS logStatus,
           SERVER_ID                           AS replicaId,
           COALESCE(VISIBILITY_LAG_IN_MSEC, 0) AS replicationLagMs
    FROM information_schema.aurora_global_db_instance_status
    WHERE SESSION_ID != 'MASTER_SESSION_ID'
  </select>

</mapper>

