    </dependency>
    <dependency>
      <groupId>io.camunda.auth</groupId>
      <artifactId>camunda-auth-idp-keycloak</artifactId>
    </dependency>
    <dependency>
      <groupId>io.camunda.auth</groupId>
      <artifactId>camunda-auth-idp-azure-ad</artifactId>
    </dependency>
    <dependency>
      <groupId>io.camunda.auth</groupId>
      <artifactId>camunda-auth-idp-auth0</artifactId>
    </dependency>
    <dependency>
      <groupId>io.camunda.auth</groupId>
      <artifactId>camunda-auth-idp-okta</artifactId>
    </dependency>
    <dependency>
      <groupId>io.camunda.auth</groupId>
      <artifactId>camunda-auth-idp-google</artifactId>
    </dependency>
    <dependency>
      <groupId>io.camunda.auth</groupId>
