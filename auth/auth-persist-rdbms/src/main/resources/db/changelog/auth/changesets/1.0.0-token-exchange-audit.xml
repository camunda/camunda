<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="1.0.0-create-token-exchange-audit" author="camunda-auth-sdk">
    <createTable tableName="TOKEN_EXCHANGE_AUDIT">
      <column name="EXCHANGE_ID" type="VARCHAR(255)">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="SUBJECT_PRINCIPAL_ID" type="VARCHAR(255)"/>
      <column name="ACTOR_PRINCIPAL_ID" type="VARCHAR(255)"/>
      <column name="TARGET_AUDIENCE" type="VARCHAR(255)"/>
      <column name="GRANTED_SCOPES" type="VARCHAR(1024)"/>
      <column name="EXCHANGE_TIME" type="TIMESTAMP(3)"/>
      <column name="EXPIRY_TIME" type="TIMESTAMP(3)"/>
      <column name="EXCHANGE_STATUS" type="VARCHAR(20)"/>
      <column name="IDP_TYPE" type="VARCHAR(50)"/>
      <column name="TENANT_ID" type="VARCHAR(255)"/>
    </createTable>

    <createIndex tableName="TOKEN_EXCHANGE_AUDIT" indexName="IDX_TEA_SUBJECT_PRINCIPAL_ID">
      <column name="SUBJECT_PRINCIPAL_ID"/>
    </createIndex>

    <createIndex tableName="TOKEN_EXCHANGE_AUDIT" indexName="IDX_TEA_EXCHANGE_TIME">
      <column name="EXCHANGE_TIME"/>
    </createIndex>
  </changeSet>

</databaseChangeLog>
