{
  "mappings": {
    "dynamic": "strict",
    "properties": {
      "id": {
        "type": "keyword"
      },
      "name": {
        "type": "keyword"
      },
      "scope": {
        "type": "keyword"
      },
      "tenantId": {
        "type": "keyword"
      },
      "value": {
        "type": "keyword",
        "ignore_above": 8191
      },
      "fullValue": {
        "type": "keyword",
        "ignore_above": 8191
      },
      "isPreview": {
        "type": "boolean"
      },
      "metadata": {
        "type": "nested",
        "properties": {
          "key":         { "type": "keyword" },
          "value":       { "type": "keyword" },
          "valueNumber": { "type": "long" }
        }
      }
    }
  }
}
