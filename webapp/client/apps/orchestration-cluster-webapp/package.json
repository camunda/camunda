{
	"name": "@camunda/orchestration-cluster-webapp",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 3000",
		"preview": "vite preview",
		"build": "vite build && node ./renameProdIndex.mjs",
		"build:visual-regression": "vite build --mode visual-regression",
		"typecheck": "tsc -p tsconfig.browser.json && tsc -p tsconfig.vitest.json && tsc -p tsconfig.node.json",
		"extract-sbom": "vite build --mode sbom",
		"test:unit": "vitest",
		"test:unit:ui": "vitest --browser.headless=false",
		"test:a11y": "playwright test --project=a11y-light --project=a11y-dark",
		"test:visual": "cross-env CONTAINERIZED_BROWSER=true playwright test --project=visual-light --project=visual-dark --project=visual-light-tablet --project=visual-dark-tablet",
		"test:integration": "playwright test --project=integration",
		"generate:svg": "svgr --typescript --no-index --out-dir src/modules/svg src/assets/svg"
	},
	"dependencies": {
		"@camunda/camunda-api-zod-schemas": "0.0.68",
		"@camunda/camunda-composite-components": "0.23.1",
		"@carbon/react": "1.106.0",
		"@tanstack/react-query": "5.100.5",
		"@tanstack/react-query-devtools": "5.100.5",
		"@tanstack/react-router": "1.170.3",
		"@tanstack/react-router-devtools": "1.167.0",
		"@tanstack/router-plugin": "1.168.5",
		"date-fns": "4.3.0",
		"final-form": "5.0.0",
		"i18next": "26.0.4",
		"i18next-browser-languagedetector": "8.2.1",
		"mixpanel-browser": "2.79.0",
		"mobx": "6.15.0",
		"mobx-react-lite": "4.1.1",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"react-final-form": "7.0.0",
		"react-i18next": "17.0.2",
		"sass": "1.100.0",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@axe-core/playwright": "4.11.2",
		"@msw/playwright": "0.6.7",
		"@playwright/test": "1.59.1",
		"@svgr/cli": "^8.1.0",
		"@tanstack/devtools-vite": "0.7.0",
		"@tanstack/react-devtools": "0.10.2",
		"@types/node": "25.9.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.1",
		"@vitest/browser-playwright": "4.1.5",
		"cross-env": "10.1.0",
		"msw": "2.14.6",
		"rollup-plugin-sbom": "3.2.0",
		"typescript": "6.0.3",
		"vite": "8.0.10",
		"vitest": "4.1.5",
		"vitest-browser-react": "2.2.0"
	}
}
