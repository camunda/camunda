{
	"name": "@camunda/orchestration-cluster-webapp",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 3000",
		"preview": "vite preview",
		"build": "vite build && node ./renameProdIndex.mjs",
		"build:visual-regression": "vite build --mode visual-regression",
		"typecheck": "tsc -p tsconfig.browser.json && tsc -p tsconfig.vitest.json && tsc -p tsconfig.node.json",
		"extract-sbom": "vite build --mode sbom",
		"test:unit": "vitest",
		"test:unit:ui": "vitest --browser.headless=false",
		"test:a11y": "playwright test --project=a11y-light --project=a11y-dark",
		"test:visual": "cross-env CONTAINERIZED_BROWSER=true playwright test --project=visual-light --project=visual-dark --project=visual-light-tablet --project=visual-dark-tablet",
		"test:integration": "playwright test --project=integration",
		"generate:svg": "svgr --typescript --no-index --out-dir src/shared/svg src/shared/assets/svg",
		"lint:knip": "knip"
	},
	"dependencies": {
		"@bpmn-io/element-template-icon-renderer": "1.0.0",
		"@camunda/camunda-api-zod-schemas": "0.0.82",
		"@camunda/camunda-composite-components": "0.25.4",
		"@carbon/grid": "11.58.0",
		"@carbon/layout": "11.55.0",
		"@carbon/react": "1.112.0",
		"@carbon/type": "11.63.0",
		"@devbookhq/splitter": "1.4.2",
		"@tanstack/react-query": "5.101.2",
		"@tanstack/react-query-devtools": "5.101.2",
		"@tanstack/react-router": "1.170.18",
		"@tanstack/react-router-devtools": "1.167.0",
		"@tanstack/router-plugin": "1.168.22",
		"@uidotdev/usehooks": "2.4.1",
		"@xstate/react": "6.1.0",
		"bpmn-js": "18.19.0",
		"date-fns": "4.4.0",
		"diagram-js-minimap": "5.4.0",
		"final-form": "5.0.1",
		"final-form-arrays": "4.0.1",
		"i18next": "26.3.6",
		"i18next-browser-languagedetector": "8.2.1",
		"mixpanel-browser": "2.81.0",
		"mobx": "6.16.1",
		"mobx-react-lite": "4.1.1",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"react-error-boundary": "6.1.2",
		"react-final-form": "7.0.1",
		"react-final-form-arrays": "5.0.0",
		"react-i18next": "17.0.10",
		"react-transition-group": "4.4.5",
		"sass": "1.101.0",
		"styled-components": "6.4.3",
		"xstate": "5.32.5",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@axe-core/playwright": "4.12.1",
		"@msw/playwright": "0.6.7",
		"@playwright/test": "1.61.1",
		"@svgr/cli": "8.1.0",
		"@tanstack/devtools-vite": "0.8.1",
		"@tanstack/react-devtools": "0.10.8",
		"@types/node": "26.1.1",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@types/react-transition-group": "4.4.12",
		"@vitejs/plugin-react": "6.0.3",
		"@vitest/browser-playwright": "4.1.10",
		"@vitest/ui": "4.1.10",
		"cross-env": "10.1.0",
		"knip": "6.27.0",
		"msw": "2.15.0",
		"rollup-plugin-sbom": "4.0.0",
		"typescript": "7.0.2",
		"vite": "8.1.5",
		"vitest": "4.1.10",
		"vitest-browser-react": "2.2.0"
	}
}
