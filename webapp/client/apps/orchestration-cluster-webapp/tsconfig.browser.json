{
	"extends": "./tsconfig.base.json",
	"include": ["src/**/*"],
	"exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "./vitest.browser.setup.ts", "src/test-extend.ts"],
	"compilerOptions": {
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.browser.tsbuildinfo",
		"jsx": "react-jsx",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"moduleDetection": "force",
		"types": ["vite/client"],
		"paths": {
			"#/modules/*": ["./src/modules/*"]
		}
	}
}
