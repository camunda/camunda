{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
		"lib": ["ES2022"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"paths": {
			"#/pw-modules/*": ["./playwright/pw-modules/*"],
			"#/shared-test-modules/*": ["./shared-test-modules/*"]
		}
	},
	"include": ["vite.config.ts", "playwright.config.ts", "playwright/**/*.ts", "shared-test-modules/**/*.ts"]
}
