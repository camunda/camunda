{
	"extends": "./tsconfig.base.json",
	"include": [
		"src/**/*",
		"src/**/*.browser.test.ts",
		"src/**/*.browser.test.tsx",
		"./src/vitest-modules/**/*.ts",
		"./shared-test-modules/**/*.ts"
	],
	"compilerOptions": {
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.vitest.browser.tsbuildinfo",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"moduleDetection": "force",
		"types": ["vite/client", "vitest", "@vitest/browser/matchers", "node"],
		"paths": {
			"#/shared/*": ["./src/shared/*"],
			"#/operate/*": ["./src/operate/*"],
			"#/tasklist/*": ["./src/tasklist/*"],
			"#/admin/*": ["./src/admin/*"],
			"#/vitest-modules/*": ["./src/vitest-modules/*"],
			"#/shared-test-modules/*": ["./shared-test-modules/*"]
		}
	}
}
