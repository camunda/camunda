  "scripts": {
    "start": "vite",
    "build": "vite build && node ./renameProdIndex.js && node license-build.js",
    "build:visual-regression": "cross-env VITE_VERSION=0.0.0-SNAPSHOT vite build --mode visual-regression",
    "test": "vitest run --project=unit",
    "test:browser": "vitest run --project=browser",
    "ts-check": "tsc -b",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier -c .",
    "lint": "npm run ts-check && npm run lint:eslint && npm run lint:prettier",
    "format": "prettier --write .",
    "test:a11y": "playwright test --project=a11y --project=a11y-dark",
    "test:visual": "cross-env CONTAINERIZED_BROWSER=true playwright test --project=visual-light --project=visual-dark",
    "generate-screenshots": "playwright test --project=screenshot-generator",
    "coverage": "npm run test -- --coverage --changed",
    "extract-sbom": "vite build --mode sbom",
    "knip": "knip --tsConfig tsconfig.app.json"
  },
  "devDependencies": {
    "@camunda/c8-mocks": "file:../../webapp/client/packages/c8-mocks",
    "@camunda/lint-config": "file:../../webapp/client/packages/lint-config",
