  "scripts": {
    "start": "vite",
    "build": "npm run ts-check && vite build && node ./renameProdIndex.js && node license-build.js",
    "build:visual-regression": "cross-env VITE_VERSION=0.0.0-SNAPSHOT vite build --mode visual-regression",
    "test": "vitest run --project=unit",
    "test:browser": "vitest run --project=browser",
    "ts-check": "tsc -b",
    "eslint": "eslint .",
    "lint": "npm run ts-check && npm run eslint",
    "fix:prettier": "prettier --write \"**/*.ts\"",
    "test:a11y": "playwright test --project=a11y",
    "test:visual": "cross-env CONTAINERIZED_BROWSER=true playwright test --project=visual-light --project=visual-dark",
    "generate-screenshots": "playwright test --project=screenshot-generator",
    "coverage": "npm run test -- --coverage --changed",
    "extract-sbom": "vite build --mode sbom",
    "knip": "knip --tsConfig tsconfig.app.json"
  },
  "devDependencies": {
    "@camunda/lint-config": "file:../../client-components/packages/lint-config",
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.58.2",
    "@testing-library/dom": "10.4.1",
