#!/bin/sh

set -eu

APP_NAME="@applicationName@"
MAIN_CLASS="@mainClass@"
APP_HOME=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)

if [ -n "${JAVA_HOME:-}" ] && [ -x "$JAVA_HOME/bin/java" ]; then
  JAVA="$JAVA_HOME/bin/java"
else
  JAVA=java
fi

DEFAULT_JVM_OPTS='@defaultJvmOpts@'
CLASSPATH="$APP_HOME/config:$APP_HOME/lib/*:$APP_HOME/driver-lib/*"

cd "$APP_HOME"

exec "$JAVA" $DEFAULT_JVM_OPTS ${JAVA_OPTS:-} -Dapp.home="$APP_HOME" -cp "$CLASSPATH" "$MAIN_CLASS" "$@"
