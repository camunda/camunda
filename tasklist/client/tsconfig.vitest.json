{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.vitest.tsbuildinfo",
    "types": ["vitest/globals", "@testing-library/jest-dom", "node"],
    "baseUrl": "src"
  },
  "include": [
    "src/**/*",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/setupTests.ts",
    "src/**/__mocks__/**/*",
    "src/modules/mocks/**/*",
    "src/**/mocks.tsx",
    "src/modules/testing/**/*"
  ]
}
