    "msw": "2.12.14",
    "prettier": "3.8.1",
    "resize-observer-polyfill": "1.5.1",
    "rollup-plugin-sbom": "3.1.0",
    "source-map-explorer": "2.5.3",
    "stylelint": "17.6.0",
    "stylelint-prettier": "5.0.3",
