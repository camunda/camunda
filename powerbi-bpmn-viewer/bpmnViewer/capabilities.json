{
    "dataRoles": [
        {
            "displayName": "BPMN XML",
            "name": "bpmnXml",
            "kind": "Grouping",
            "description": "BPMN 2.0 XML definition to render"
        },
        {
            "displayName": "Flow Node ID",
            "name": "flowNodeId",
            "kind": "Grouping",
            "description": "Flow node identifiers for heatmap"
        },
        {
            "displayName": "Execution Count",
            "name": "executionCount",
            "kind": "Measure",
            "description": "Number of times each flow node was executed"
        }
    ],
    "objects": {},
    "dataViewMappings": [
        {
            "categorical": {
                "categories": {
                    "for": {
                        "in": "bpmnXml"
                    },
                    "dataReductionAlgorithm": {
                        "top": {
                            "count": 1
                        }
                    }
                }
            }
        },
        {
            "categorical": {
                "categories": {
                    "for": {
                        "in": "flowNodeId"
                    }
                },
                "values": {
                    "select": [
                        {
                            "bind": {
                                "to": "executionCount"
                            }
                        }
                    ]
                }
            }
        }
    ],
    "privileges": []
}
