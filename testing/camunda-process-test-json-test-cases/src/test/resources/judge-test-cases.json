{
  "$schema": "https://camunda.com/json-schema/cpt-test-cases/8.9/schema.json",
  "testCases": [
    {
      "name": "Judge assertion - global variable",
      "instructions": [
        {
          "type": "ASSERT_VARIABLE_JUDGE",
          "processInstanceSelector": {
            "processDefinitionId": "ai-agent-process"
          },
          "variableName": "agentResponse",
          "expectation": "should contain a valid summary of the financial report"
        }
      ]
    },
    {
      "name": "Judge assertion - local variable with overrides",
      "instructions": [
        {
          "type": "ASSERT_VARIABLE_JUDGE",
          "processInstanceSelector": {
            "processDefinitionId": "ai-agent-process"
          },
          "variableName": "localResult",
          "expectation": "should be a properly formatted JSON response",
          "elementSelector": {
            "elementId": "ai-subprocess"
          },
          "threshold": 0.8,
          "customPrompt": "You are evaluating data accuracy"
        }
      ]
    }
  ]
}
