<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <parent>
    <groupId>io.camunda</groupId>
    <artifactId>camunda-testing</artifactId>
    <version>8.10.0-SNAPSHOT</version>
    <relativePath>../pom.xml</relativePath>
  </parent>

  <artifactId>camunda-process-test-coverage-frontend-new</artifactId>
  <packaging>pom</packaging>

  <name>Camunda Process Test Coverage Frontend (New)</name>
  <description>Lightweight vanilla-JS frontend for visualising Camunda process test coverage reports.
    Builds static HTML/CSS/JS resources that are bundled into the camunda-process-test-java JAR
    and used by CoverageReportUtil to produce self-contained HTML coverage reports.</description>

  <licenses>
    <license>
      <name>Apache License, Version 2.0</name>
      <url>http://www.apache.org/licenses/LICENSE-2.0</url>
    </license>
  </licenses>

  <properties>
    <skip.fe.build>false</skip.fe.build>
    <!--
      Output directory consumed by camunda-process-test-java as a resource directory.
      The path matches the resource directory declared in that module's pom.xml.
    -->
    <fe.build.output.dir>${project.basedir}/../camunda-process-test-java/target/generated-frontend-resources/coverage</fe.build.output.dir>
  </properties>

  <build>
    <plugins>
      <plugin>
        <groupId>com.github.eirslett</groupId>
        <artifactId>frontend-maven-plugin</artifactId>
        <configuration>
          <workingDirectory>${project.basedir}</workingDirectory>
          <installDirectory>${project.basedir}</installDirectory>
        </configuration>
        <executions>

          <!-- 1. Install Node and npm -->
          <execution>
            <id>install-node-and-npm</id>
            <goals>
              <goal>install-node-and-npm</goal>
            </goals>
            <phase>initialize</phase>
            <configuration>
              <skip>${skip.fe.build}</skip>
              <nodeVersion>v24.13.0</nodeVersion>
              <npmVersion>11.9.0</npmVersion>
            </configuration>
          </execution>

          <!-- 2. Install npm dependencies -->
          <execution>
            <id>npm-install</id>
            <goals>
              <goal>npm</goal>
            </goals>
            <phase>initialize</phase>
            <configuration>
              <skip>${skip.fe.build}</skip>
              <arguments>install</arguments>
            </configuration>
          </execution>

          <!-- 3. Build (assemble vendor files + copy sources) -->
          <execution>
            <id>npm-build</id>
            <goals>
              <goal>npm</goal>
            </goals>
            <phase>generate-resources</phase>
            <configuration>
              <skip>${skip.fe.build}</skip>
              <arguments>run build</arguments>
              <environmentVariables>
                <BUILD_PATH>${fe.build.output.dir}</BUILD_PATH>
              </environmentVariables>
            </configuration>
          </execution>

        </executions>
      </plugin>
    </plugins>
  </build>

  <profiles>
    <profile>
      <id>skipFrontendBuild</id>
      <properties>
        <skip.fe.build>true</skip.fe.build>
      </properties>
    </profile>
  </profiles>
</project>
